{
  "hooks": [
    {
      "event": "PreToolUse",
      "matcher": "Edit",
      "hooks": [
        {
          "type": "command",
          "command": "python3 scripts/lint_sources.py"
        }
      ]
    },
    {
      "event": "PreToolUse",
      "matcher": "Write",
      "hooks": [
        {
          "type": "command",
          "command": "python3 scripts/lint_sources.py"
        }
      ]
    }
  ]
}
