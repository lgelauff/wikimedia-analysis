# Environment variables for source-collection/fetch.py
#
# Copy this file to .env (or to your credentials vault) and fill in the values.
# Load before running: set -a && source /path/to/.env && set +a
#
# Variables marked REQUIRED must be set for the relevant pipeline stage to work.
# Variables marked OPTIONAL improve behaviour but have a working fallback.

# ---------------------------------------------------------------------------
# Internet Archive — SavePageNow v2 (SPN2)
# REQUIRED for the spn2 pipeline stage.
# Obtain at: https://archive.org/account/s3.php
# ---------------------------------------------------------------------------
IA_ACCESS_KEY=
IA_SECRET_KEY=

# ---------------------------------------------------------------------------
# Crossref — polite pool
# OPTIONAL. Without this, requests go to the anonymous pool (5s rate limit).
# With it, requests go to the polite pool (1s rate limit, dedicated infra).
# Set to your email address. Crossref uses it only to contact you if your
# usage looks problematic; it appears in their server logs but nowhere else.
# Reference: https://www.crossref.org/documentation/retrieve-metadata/rest-api/tips-for-using-the-crossref-rest-api/
# ---------------------------------------------------------------------------
CROSSREF_MAILTO=

# ---------------------------------------------------------------------------
# Wikimedia account — bot password (MediaWiki Action API)
# OPTIONAL. Identifies requests as coming from your account on the MediaWiki
# Action API (/w/api.php). Does not raise the hard rate limit for reads, but
# is good practice and makes your traffic identifiable to Wikimedia ops.
#
# Create a bot password at: https://en.wikipedia.org/wiki/Special:BotPasswords
#   1. Give it a name (e.g. "source-collection")
#   2. Grant: "Basic rights" is sufficient for read-only use
#   3. You receive a username like "YourAccount@source-collection" and a password
#
# Set WIKIMEDIA_USERNAME to the full bot username (YourAccount@source-collection)
# Set WIKIMEDIA_BOT_PASSWORD to the generated password
# ---------------------------------------------------------------------------
WIKIMEDIA_USERNAME=
WIKIMEDIA_BOT_PASSWORD=

# ---------------------------------------------------------------------------
# Wikimedia OAuth 2.0 (api.wikimedia.org — higher rate limits)
# OPTIONAL. Required only if you use api.wikimedia.org endpoints directly
# (e.g. the Wikimedia API Gateway or Lift Wing ML models).
# Without this, api.wikimedia.org is limited to 500 req/hour (anonymous).
# With it, the limit rises to 5,000 req/hour.
#
# Owner-only consumers are active immediately (no admin approval needed).
# Create at: https://meta.wikimedia.org/wiki/Special:OAuthConsumerRegistration
#   - Select "This consumer is for use only by [your username]"
#   - Grants needed for read-only: "Interact with pages" (basic)
#   - Scope: "basic" (not "openid" — that returns invalid_scope on Wikimedia)
#
# Reference: https://www.mediawiki.org/wiki/OAuth/For_Developers/OAuth_2.0
# Lesson: https://github.com/lgelauff/wikimedia-coding-agent-lessons
# ---------------------------------------------------------------------------
WIKIMEDIA_OAUTH_CLIENT_ID=
WIKIMEDIA_OAUTH_CLIENT_SECRET=
WIKIMEDIA_OAUTH_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Wikimedia Enterprise API
# OPTIONAL. Without this, Wikimedia pages are fetched via the public
# MediaWiki Action API (anonymous, 8s rate limit).
# With it, the Enterprise API is used (authenticated, 1s rate limit, richer output).
# Obtain at: https://enterprise.wikimedia.com/
# ---------------------------------------------------------------------------
WIKIMEDIA_ENTERPRISE_KEY=

# ---------------------------------------------------------------------------
# Toolforge / Wikimedia SQL replicas
# OPTIONAL. Only needed if you extend the pipeline to query production
# database replicas (e.g. pageview data, article quality grades).
# Obtain replica credentials at: https://toolsdb.wmcloud.org/
# Reference: https://wikitech.wikimedia.org/wiki/Help:Toolforge/Database
# ---------------------------------------------------------------------------
TOOLFORGE_USER=
TOOLFORGE_SQL_USER=
TOOLFORGE_SQL_PASSWORD=
TOOLFORGE_DB_PORT=3307
